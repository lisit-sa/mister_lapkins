{
  "hosting": {
    "public": "hosting",
    "ignore": ["firebase.json", "**/.*", "!/.well-known/**", "**/node_modules/**"],
    "headers": [
      {
        "source": "/updates/version.json",
        "headers": [
          { "key": "Access-Control-Allow-Origin", "value": "*" },
          { "key": "Cache-Control", "value": "no-cache, max-age=0" }
        ]
      },
      {
        "source": "/updates/*.zip",
        "headers": [{ "key": "Access-Control-Allow-Origin", "value": "*" }]
      }
    ]
  }
}
