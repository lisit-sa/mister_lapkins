{
  "name": "mister_lapkins",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "sync": "npm run build:cloudsync && npm run build:audio && npm run build:updater && npm run build:haptics && npm run build:notifications && npm run build:battery && npm run build:deeplink && npm run build:share && cap sync android && npm run sync:sounds",
    "sync:sounds": "node scripts/sync-sounds.js",
    "open:android": "cap open android",
    "build:cloudsync": "esbuild src/cloud-sync.js --bundle --format=iife --outfile=www/cloud-sync.bundle.js",
    "build:audio": "esbuild src/audioManager.js --bundle --format=iife --outfile=www/audio-manager.bundle.js",
    "build:updater": "esbuild src/updater.js --bundle --format=iife --outfile=www/updater.bundle.js",
    "build:haptics": "esbuild src/haptics.js --bundle --format=iife --outfile=www/haptics.bundle.js",
    "build:notifications": "esbuild src/notifications.js --bundle --format=iife --outfile=www/notifications.bundle.js",
    "build:battery": "esbuild src/battery.js --bundle --format=iife --outfile=www/battery.bundle.js",
    "build:deeplink": "esbuild src/deeplink.js --bundle --format=iife --outfile=www/deeplink.bundle.js",
    "build:share": "esbuild src/share.js --bundle --format=iife --outfile=www/share.bundle.js",
    "icons:prep": "node scripts/prep-icon.js",
    "icons": "npm run icons:prep && capacitor-assets generate --android",
    "release": "npm run build:cloudsync && npm run build:audio && npm run build:updater && npm run build:haptics && npm run build:notifications && npm run build:battery && npm run build:deeplink && npm run build:share && node scripts/release.js",
    "deploy": "npm run release && firebase deploy --only hosting"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lisit-sa/mister_lapkins.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/lisit-sa/mister_lapkins/issues"
  },
  "homepage": "https://github.com/lisit-sa/mister_lapkins#readme",
  "dependencies": {
    "@capacitor-community/native-audio": "^8.0.0",
    "@capacitor-firebase/authentication": "^8.3.0",
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/local-notifications": "^8.2.1",
    "@capacitor/share": "^8.0.1",
    "@capgo/capacitor-updater": "^8.51.2",
    "firebase": "^12.16.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "archiver": "^7.0.1",
    "esbuild": "^0.28.1",
    "firebase-tools": "^15.24.0",
    "sharp": "^0.32.6"
  }
}
